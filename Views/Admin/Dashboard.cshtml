@foreach (var block in Model.BlockSummaries)
{
    <input type="hidden"
           class="block-data"
           data-phase="@block.Phase"
           data-block="@block.Block"
           data-paid="@block.PaidCount"
           data-unpaid="@block.UnpaidCount" />
}

<div id="mapTooltip" class="map-tooltip" style="display:none;"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const tooltip = document.getElementById("mapTooltip");

        document.querySelectorAll("#mapVisualization path").forEach(path => {
            if (!path.dataset.phase || !path.dataset.block) return;

            const phase = path.dataset.phase;
            const block = path.dataset.block;

            const data = document.querySelector(
    `.block-data[data-phase='${phase}'][data-block='${block}']`
    );

            let paid = 0;
            let unpaid = 0;

            if (data) {
                paid = parseInt(data.dataset.paid);
                unpaid = parseInt(data.dataset.unpaid);
            }

            const total = paid + unpaid;
            const majority = Math.floor(total / 2) + 1;

            // COLOR LOGIC
            if (total === 0) {
                path.style.fill = "#9ca3af"; 
            }
            else if (paid >= majority) {
                path.style.fill = "#22c55e"; 
            }
            else if (paid === unpaid) {
                path.style.fill = "#facc15";
            }
            else {
                path.style.fill = "#ef4444"; 
            }

            path.addEventListener("mouseenter", function (e) {
                tooltip.innerHTML = `
                    <strong>Block ${block} - Phase ${phase}</strong><br>
                    Paid: ${paid}<br>
                    Unpaid: ${unpaid}<br>
                `;
                tooltip.style.display = "block";
            });

            path.addEventListener("mousemove", function (e) {
                tooltip.style.left = (e.pageX + 12) + "px";
                tooltip.style.top = (e.pageY + 12) + "px";
            });

            path.addEventListener("mouseleave", function () {
                tooltip.style.display = "none";
            });
        });
    });
</script>
