    <div id="rowMenu" class="context-menu">
        @if (Context.Session.GetString("CanEditInvoice") == "True" || Context.Session.GetString("IsPrimary") == "True")
        {
            <a id="editRow">Edit</a>
        }
        @if (Context.Session.GetString("IsPrimary") == "True")
        {
            <a id="deleteRow">Delete</a>
        }
    </div>




    <script>
        let clickedId = null;

                document.addEventListener("contextmenu", function (e) {
            const row = e.target.closest("tr[data-id]");
            if (!row) return;

            if (row.dataset.status === "Paid") return;

            const canEdit = "@Context.Session.GetString("CanEditInvoice")" === "True";
            const isPrimary = "@Context.Session.GetString("IsPrimary")" === "True";

            if (!canEdit && !isPrimary) return;

            e.preventDefault();
            e.stopPropagation();

            clickedId = row.dataset.id;

            const menu = document.getElementById("rowMenu");
            menu.style.left = e.pageX + "px";
            menu.style.top = e.pageY + "px";
            menu.style.display = "block";
        });


        document.addEventListener("click", function () {
            document.getElementById("rowMenu").style.display = "none";
        });

        document.getElementById("editRow").onclick = function (e) {
            e.stopPropagation();

            document.getElementById("rowMenu").style.display = "none";

            const row = document.querySelector(`tr[data-id='${clickedId}']`);

            document.getElementById("editInvoiceId").value = clickedId;
            document.getElementById("editInvoiceNo").value = row.children[0].innerText;
            document.getElementById("editBillingPeriod").value = row.children[1].innerText;
            document.getElementById("editAmount").value = row.dataset.amount;
            document.getElementById("editDescription").value = row.dataset.description;

            const modal = new bootstrap.Modal(
                document.getElementById("editInvoiceModal")
            );
            modal.show();
        };


            document.getElementById("deleteRow").onclick = function (e) {
            e.stopPropagation();

            if (!confirm("Are you sure you want to delete this unpaid invoice?")) return;

            document.getElementById("deleteInvoiceId").value = clickedId;
            document.getElementById("deleteInvoiceForm").action = "/Admin/DeleteInvoice";
            document.getElementById("deleteInvoiceForm").submit();
        };
    </script>



    <div class="modal fade" id="editInvoiceModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">

                <h4 class="fw-bold text-center mb-3">Edit Invoice</h4>
                <form method="post" action="/Admin/EditInvoice" onsubmit="return confirmEditInvoice();">


                    <input type="hidden" name="Invoice_No" id="editInvoiceId">
                    <input type="hidden" name="ResidentId" value="@Model.Resident.Resident_Id">

                    <div class="mb-3">
                        <label>Invoice No.</label>
                        <input type="text" id="editInvoiceNo" class="form-control" readonly>
                    </div>

                    <div class="mb-3">
                        <label>Billing Period</label>
                        <input type="text" id="editBillingPeriod" class="form-control" readonly>
                    </div>

                    <div class="mb-3">
                        <label>Total Amount *</label>
                        <input type="number" step="0.01" name="Total_Amount"
                               id="editAmount" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Description</label>
                        <textarea name="Description"
                                  id="editDescription"
                                  class="form-control"></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-orange">
                            Save Changes
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>


