    <script>
        let selectedExpenseId = null;

        document.querySelectorAll(".table-container table tbody tr").forEach(row => {
            row.addEventListener("contextmenu", function (e) {
                e.preventDefault();
                document.querySelectorAll(".table-container tbody tr")
                    .forEach(r => r.classList.remove("active-row"));

                // highlight current row
                this.classList.add("active-row");

                selectedExpenseId = this.dataset.expenseId;

                const menu = document.getElementById("expenseRowMenu");
                menu.style.top = `${e.pageY}px`;
                menu.style.left = `${e.pageX}px`;
                menu.classList.add("show");
            });
        });
        document.addEventListener("click", () => {
            document.querySelectorAll(".table-container tbody tr")
                .forEach(r => r.classList.remove("active-row"));

            document.getElementById("expenseRowMenu")?.classList.remove("show");
        });
    </script>

