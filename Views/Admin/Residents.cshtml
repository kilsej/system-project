@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var success = "@(TempData["ResidentStatusSuccess"] ?? "")";

            if (success !== "") {
                var modal = new bootstrap.Modal(
                    document.getElementById("residentStatusSuccessModal")
                );
                modal.show();
            }

        });
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const select = document.getElementById("invYear");
            if (!select) return;

            const currentYear = new Date().getFullYear();
            let found = false;

            // remove duplicates
            const seen = new Set();
            [...select.options].forEach(opt => {
                if (seen.has(opt.value)) {
                    opt.remove();
                } else {
                    seen.add(opt.value);
                }
            });

            // force-select current year
            [...select.options].forEach(opt => {
                if (parseInt(opt.value) === currentYear) {
                    opt.selected = true;
                    found = true;
                }
            });

            if (!found && select.options.length > 0) {
                select.selectedIndex = 0;
            }
        });
    </script>



    <script>
                $('#createInvoiceModal').on('shown.bs.modal', function () {
            loadInvoiceHeader();
        });
    </script>
    <script>
        function resetPaymentUI() {
            document.getElementById("payName").value = "";
            document.getElementById("payInvoiceContainer").innerHTML = "";
            document.getElementById("payAmount").value = "";
        }

        async function loadPaymentData() {

            const block = document.getElementById("payBlock").value.trim();
            const lot = document.getElementById("payLot").value.trim();
            const phase = document.getElementById("payPhase").value.trim();

            if (!block || !lot || !phase) {
                resetPaymentUI();
                return;
            }

            // Fetch resident by address
            const res = await fetch(`/Admin/GetResidentByAddress?block=${block}&lot=${lot}&phase=${phase}`);
            const resident = await res.json();

            if (!resident) {
                resetPaymentUI();
                return;
            }

            document.getElementById("payName").value = resident.fullName;

            // Fetch unpaid invoices of that resident
            const invres = await fetch(`/Admin/GetUnpaidInvoices?residentId=${resident.residentId}`);
            const invoices = await invres.json();

            const box = document.getElementById("payInvoiceContainer");
            box.innerHTML = "";

            if (invoices.length === 0) {
                box.innerHTML = `<p class="text-muted">No unpaid invoices.</p>`;
                return;
            }

            invoices.forEach(inv => {
                const html = `
                <div class="form-check">
                    <input type="checkbox"
                           class="form-check-input pay-invoice-check"
                           name="InvoiceNos"
                           value="${inv.invoiceNo}"
                           data-amount="${inv.amount}"
                           id="inv_${inv.invoiceNo}">

                    <label class="form-check-label" for="inv_${inv.invoiceNo}">
                        Invoice #${inv.invoiceNo} — ${inv.month} ${inv.year} — ₱${inv.amount}
                    </label>
                </div>`;
                box.insertAdjacentHTML("beforeend", html);
            });

            document.querySelectorAll(".pay-invoice-check")
                .forEach(chk => chk.addEventListener("change", updatePaymentTotal));
        }

        function updatePaymentTotal() {
            let total = 0;
            document.querySelectorAll(".pay-invoice-check:checked")
                .forEach(c => total += parseFloat(c.dataset.amount));

            document.getElementById("payAmount").value =
                total > 0 ? total.toFixed(2) : "";
        }

        document.addEventListener("DOMContentLoaded", function () {

            ["payBlock", "payLot", "payPhase"].forEach(id => {
                const el = document.getElementById(id);

                el.addEventListener("input", resetPaymentUI);
                el.addEventListener("blur", loadPaymentData);
            });
        });
    </script>

    <script>
            document.getElementById('btnClear').addEventListener('click', function() {
        
            const fieldsToClear = document.querySelectorAll('input:not(.keep), textarea:not(.keep), select:not(.keep)');

            fieldsToClear.forEach(field => {
                if (field.type === 'checkbox' || field.type === 'radio') {
                    field.checked = false;
                } else {
                    field.value = '';
                }
            });
        });
    </script>

    <script>
                document.getElementById("btnClear").addEventListener("click", function () {
            document.getElementById("invTotal").value = 0;

            document.querySelectorAll(".month-checkbox").forEach(cb => {
                cb.checked = false;
            });
        });
    </script>
    <script>
            document.getElementById('clearBtn').addEventListener('click', function() {
            
            const fieldsToClear = document.querySelectorAll('input:not(.keep), textarea:not(.keep), select:not(.keep)');

            fieldsToClear.forEach(field => {
                if (field.type === 'checkbox' || field.type === 'radio') {
                    field.checked = false;
                } else {
                    field.value = '';
                }
            });
        });
    </script>

    <script>
        function resetInvoiceUI() {
            // Clear name & email
            document.getElementById("invName").value = "";

            // Reset all month checkboxes
            document.querySelectorAll(".month-checkbox").forEach(cb => {
                cb.disabled = false;
                cb.checked = false;
                cb.closest(".form-check").style.opacity = "1";
            });
        }

        async function loadResidentAndMonths() {

            const block = document.getElementById("invBlock").value.trim();
            const lot = document.getElementById("invLot").value.trim();
            const phase = document.getElementById("invPhase").value.trim();
            const year = document.getElementById("invYear").value;

            // If any field missing → reset and stop
            if (!block || !lot || !phase || !year) {
                resetInvoiceUI();
                return;
            }

            // 🔎 GET RESIDENT
            const res = await fetch(`/Admin/GetResidentByAddress?block=${block}&lot=${lot}&phase=${phase}`);
            const resident = await res.json();

            if (!resident) {
                resetInvoiceUI();
                return;
            }

            // Fill name/email
            document.getElementById("invName").value = resident.fullName;
  

            // 📅 GET DISABLED MONTHS
            const mres = await fetch(`/Admin/GetExistingInvoiceMonths?block=${block}&lot=${lot}&phase=${phase}&year=${year}`);
            const disabledMonths = await mres.json();

            // Reset first
            document.querySelectorAll(".month-checkbox").forEach(cb => {
                cb.disabled = false;
                cb.checked = false;
                cb.closest(".form-check").style.opacity = "1";
            });

            // Disable existing months
            disabledMonths.forEach(m => {
