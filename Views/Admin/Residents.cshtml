    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const durationContainer = document.getElementById("durationContainer");
            const monthCheckboxes = document.querySelectorAll(".month-checkbox");
            const useDuration = document.getElementById("useDuration");
            const yearSelect = document.getElementById("invYear");

            function checkFutureMonths() {
                const now = new Date();
                const currentMonth = now.getMonth() + 1;
                const currentYear = now.getFullYear();

                const selectedYear = parseInt(yearSelect.value);

                let hasFutureMonth = false;

                monthCheckboxes.forEach(cb => {
                    if (cb.checked) {
                        const selectedMonth = parseInt(cb.value);

                        // ✅ FULL DATE COMPARISON
                        if (
                            selectedYear > currentYear ||
                            (selectedYear === currentYear && selectedMonth > currentMonth)
                        ) {
                            hasFutureMonth = true;
                        }
                    }
                });

                if (hasFutureMonth && useDuration.checked) {
                    durationContainer.classList.remove("d-none");
                } else {
                    durationContainer.classList.add("d-none");
                }
            }

            // Month checkbox events
            monthCheckboxes.forEach(cb => {
                cb.addEventListener("change", checkFutureMonths);
            });

            // Year change event (IMPORTANT)
            yearSelect.addEventListener("change", checkFutureMonths);

            // Toggle duration usage
            useDuration.addEventListener("change", checkFutureMonths);

        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const rateInput = document.getElementById("invRate");
            const advanceCheckbox = document.getElementById("advancePayment");
            const totalInput = document.getElementById("invTotal");
            const setDefaultBtn = document.getElementById("btnSetDefaultRate");
            const modal = document.getElementById("createInvoiceModal");


            let originalRate = parseFloat(rateInput.value) || 0;

            function calculateTotal() {
                let rate = parseFloat(rateInput.value) || 0;

                const checkedMonths = document.querySelectorAll(".month-checkbox:checked");
                const numberOfMonths = checkedMonths.length;

                const total = rate * numberOfMonths;

                totalInput.value = total > 0
                    ? total.toLocaleString("en-PH")
                    : "0";
            }

                    modal.addEventListener("shown.bs.modal", function () {
            const savedRate = localStorage.getItem("defaultRate");

            if (savedRate) {
                rateInput.value = savedRate;
                originalRate = parseFloat(savedRate);
            } else {
                originalRate = parseFloat(rateInput.value) || 0;
            }

            advanceCheckbox.checked = false;
            setDefaultBtn.classList.add("d-none"); // reset button

            calculateTotal();
        });

            rateInput.addEventListener("input", function () {

            const currentRate = parseFloat(rateInput.value) || 0;

            if (!advanceCheckbox.checked) {
                originalRate = currentRate;
            }

            const savedRate = parseFloat(localStorage.getItem("defaultRate")) || originalRate;

            if (currentRate !== savedRate) {
                setDefaultBtn.classList.remove("d-none");
            } else {
                setDefaultBtn.classList.add("d-none");
            }

            calculateTotal();
        });

            advanceCheckbox.addEventListener("change", function () {

                if (advanceCheckbox.checked) {
                    const discounted = originalRate * 0.9;
                    rateInput.value = discounted.toFixed(2);
                } else {
                    rateInput.value = originalRate;
                }

                calculateTotal();
            });

            setDefaultBtn.addEventListener("click", function () {
                const newRate = parseFloat(rateInput.value);

                if (!newRate || newRate <= 100) {
                    alert("Please enter a valid rate. Must be more than PHP 100.");
                    return;
                }

                localStorage.setItem("defaultRate", newRate);

                alert("Default rate saved!");

                originalRate = newRate;
                setDefaultBtn.classList.add("d-none");
            });

            document.querySelectorAll(".month-checkbox").forEach(cb => {
                cb.addEventListener("change", calculateTotal);
            });

        });
    </script>

