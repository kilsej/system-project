    <script>
        function openEditResidentModal(row) {

            document.getElementById("residentMenu").style.display = "none";

            const fullName = row.dataset.fullname || "";

            let lastName = "";
            let firstName = "";
            let middleName = "";

            // Expected formats:
            // "Lastname, Firstname Middlename"
            // "Lastname, Firstname"
            if (fullName.includes(",")) {
                const [last, rest] = fullName.split(",");
                lastName = last.trim();

                const nameParts = rest.trim().split(" ");
                firstName = nameParts[0] || "";
                middleName = nameParts.length > 1
                    ? nameParts.slice(1).join(" ")
                    : "";
            } else {
                // Fallback: "Firstname Middlename Lastname"
                const parts = fullName.split(" ");
                firstName = parts[0] || "";
                lastName = parts.length > 1 ? parts[parts.length - 1] : "";
                middleName = parts.length > 2 ? parts.slice(1, -1).join(" ") : "";
            }

            document.getElementById("editResidentId").value = row.dataset.id;
            const year = row.dataset.year;
            const yy = year.slice(-2);
            const paddedId = row.dataset.id.padStart(4, "0");

            document.getElementById("editResidentIdDisplay").value = `R${yy}-${paddedId}`;
            document.getElementById("editLastName").value = lastName;
            document.getElementById("editFirstName").value = firstName;
            document.getElementById("editMiddleName").value = middleName;

            document.getElementById("editBlock").value = row.dataset.block || "";
            document.getElementById("editLot").value = row.dataset.lot || "";
            document.getElementById("editPhase").value = row.dataset.phase || "";
            document.getElementById("editYear").value = row.dataset.year || "";
            document.getElementById("editStatus").value = row.dataset.status || "Active";
            document.getElementById("editEmail").value = row.dataset.email || "";
            document.getElementById("editContact").value = row.dataset.contact || "";
            document.getElementById("editUsername").value = row.dataset.username || "";
            document.getElementById("editPassword").value =
                row.dataset.password ? row.dataset.password : "********";


            new bootstrap.Modal(
                document.getElementById("editResidentModal")
            ).show();
        }
    </script>

