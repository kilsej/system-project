@{
    ViewData["Title"] = "Verify Email";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Email - Carlton Residences</title>
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f36f21;
        }

        .btn-primary-custom {
            background-color: #f36f21;
            border-color: #f36f21;
            color: white;
        }

            .btn-primary-custom:hover {
                background-color: #d65a10;
                color: white;
            }</style>
</head>
<body style="background-color: #f36f21;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-7 col-md-9">
                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-2">Verify Your Email</h1>
                                <p class="mb-4">We sent a verification code to your email. Enter it below to finish setup.</p>
                            </div>
                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger">@ViewBag.Error</div>
                            }
                            <form class="user" method="post" action="@Url.Action("VerifyAdminSetup", "Admin")">
                                <div class="form-group">
                                    <input type="text" name="Code" class="form-control form-control-user text-center" placeholder="Enter 4-Digit Code" maxlength="4" required style="font-size: 1.5rem; letter-spacing: 5px;">
                                </div>
                                <button type="submit" class="btn btn-primary-custom btn-user btn-block">Complete Setup</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>